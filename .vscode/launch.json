{
    "version": "0.2.0",
    "comment": "Debug configs for the most-used hephaestus-* CLIs. Each entry runs the CLI inside the pixi env's interpreter so dev-installed package code is on the import path. Adjust `args` to the scenario you want to step through.",
    "configurations": [
        {
            "name": "Run unit tests (current file)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "--no-cov"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Run unit tests (all)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/unit",
                "-v",
                "--no-cov"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "hephaestus-plan-issues --dry-run --issues 1",
            "type": "debugpy",
            "request": "launch",
            "module": "hephaestus.automation.planner",
            "args": [
                "--dry-run",
                "--issues",
                "1"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "hephaestus-implement-issues --dry-run --issues 1",
            "type": "debugpy",
            "request": "launch",
            "module": "hephaestus.automation.implementer",
            "args": [
                "--dry-run",
                "--issues",
                "1"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "hephaestus-review-prs --dry-run --issues 1",
            "type": "debugpy",
            "request": "launch",
            "module": "hephaestus.automation.pr_reviewer",
            "args": [
                "--dry-run",
                "--issues",
                "1"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "hephaestus-automation-loop --dry-run --loops 1",
            "type": "debugpy",
            "request": "launch",
            "module": "hephaestus.automation.loop_runner",
            "args": [
                "--dry-run",
                "--loops",
                "1"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "hephaestus-merge-prs --dry-run",
            "type": "debugpy",
            "request": "launch",
            "module": "hephaestus.github.pr_merge",
            "args": [
                "--dry-run"
            ],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.pixi/envs/default/bin/python",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}
